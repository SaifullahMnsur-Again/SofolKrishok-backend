# ============================================
# SOFOLKRISHOK ENVIRONMENT CONFIGURATION
# ============================================
# This file has sections for:
# - LOCAL DEVELOPMENT (use SQLite, localhost)
# - PRODUCTION/DIGITALOCEAN (use PostgreSQL, your domain)
#
# Copy this file to .env and fill in your values based on your environment.
# NEVER commit .env to version control!
# ============================================

# ============================================
# DJANGO CORE SETTINGS
# ============================================
# SECRET_KEY: Generate using: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-generated-secret-key-here

# DEBUG: Set to 'True' for local development ONLY. ALWAYS 'False' for production!
DEBUG=False

# ALLOWED_HOSTS: Comma-separated list of domains your site will serve
# LOCAL: localhost,127.0.0.1
# PRODUCTION: your-domain.com,www.your-domain.com,subdomain.domain.tld
ALLOWED_HOSTS=localhost,127.0.0.1

# FRONTEND_URL: Frontend domain (used for CORS and redirects)
# LOCAL: http://localhost:5173
# PRODUCTION: https://subdomain.domain.tld
FRONTEND_URL=http://localhost:5173

# ============================================
# DATABASE CONFIGURATION
# ============================================
# For LOCAL development, you can use SQLite (comment out these and set DB_ENGINE to django.db.backends.sqlite3)
# For PRODUCTION, use PostgreSQL (recommended)

# DB_ENGINE: Database backend
# SQLite (local): django.db.backends.sqlite3
# PostgreSQL (production): django.db.backends.postgresql
DB_ENGINE=django.db.backends.postgresql

# PostgreSQL Credentials (for production)
# Generate strong password: python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_NAME=sofolkrishok_db
DB_USER=sofolkrishok_user
DB_PASSWORD=your-strong-random-password-here
DB_HOST=localhost
DB_PORT=5432

# For SQLite (local development), just set:
# DB_NAME=db.sqlite3
# And comment out the PostgreSQL settings above

# ============================================
# REDIS CONFIGURATION (Celery & Caching)
# ============================================
# LOCAL: redis://localhost:6379/0
# PRODUCTION: redis://localhost:6379/0 (same, unless using separate Redis server)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# CORS & SECURITY
# ============================================
# CORS_ALLOWED_ORIGINS: Comma-separated list of frontend domains
# LOCAL: http://localhost:5173
# PRODUCTION: https://subdomain.domain.tld
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ============================================
# EXTERNAL API KEYS
# ============================================
# CRITICAL: Get these from your respective service providers
# NEVER commit real API keys to version control!
# Generate these from:
# - Gemini API: console.cloud.google.com (Google Cloud)
# - OpenWeather API: openweathermap.org
# - SSLCommerz: sslcommerz.com

# Gemini API (Google Cloud)
# Get from: console.cloud.google.com/apis
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_SECONDARY_MODEL=gemini-2.5-flash-lite-preview
GEMINI_TERTIARY_MODEL=gemini-2.5-flash

# OpenWeather API
# Get from: openweathermap.org/api
OPENWEATHER_API_KEY=
WEATHER_FORECAST_DAYS=5

# SSLCommerz Payment Gateway (Bangladesh)
# Get from: sslcommerz.com
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=True  # Set to False for production payments

# ============================================
# QUICK SETUP GUIDE
# ============================================
# 
# LOCAL DEVELOPMENT:
# 1. Copy this file to .env
# 2. Set DEBUG=True
# 3. For SQLite: Set DB_ENGINE=django.db.backends.sqlite3, DB_NAME=db.sqlite3
# 4. For PostgreSQL (recommended even locally): Create DB and user, set credentials
# 5. Run: python manage.py migrate
# 6. Run: python manage.py runserver
#
# PRODUCTION (DigitalOcean):
# 1. Copy this file to .env on server
# 2. Set DEBUG=False
# 3. Update ALLOWED_HOSTS with your domain
# 4. Update CORS_ALLOWED_ORIGINS with your frontend URL
# 5. Set DB_ENGINE=django.db.backends.postgresql with real credentials
# 6. Set all API keys (GEMINI_API_KEY, OPENWEATHER_API_KEY, etc.)
# 7. Run: python manage.py migrate
# 8. Run: python manage.py collectstatic --noinput
# 9. Start with Gunicorn: gunicorn sofolkrishok.wsgi:application --bind 0.0.0.0:8000
#
# ============================================
