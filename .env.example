# Django core
SECRET_KEY=change-me-in-production
DEBUG=False
ALLOWED_HOSTS=your-domain.com,localhost,127.0.0.1
FRONTEND_URL=https://your-frontend-domain.com

# Database (SQLite for local, PostgreSQL for production)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# AI models
DISEASE_MODEL_DIR=/app/ml_models/disease_detection
SOIL_MODEL_PATH=/app/ml_models/soil_classification/soil_type_model.h5

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_SECONDARY_MODEL=gemini-2.5-flash-lite-preview
GEMINI_TERTIARY_MODEL=gemini-2.5-flash

# Weather + speech
OPENWEATHER_API_KEY=
WEATHER_FORECAST_DAYS=5
WHISPER_BN_MODEL_PATH=/app/banglaspeech2text/whisper-base-bn

# SSLCommerz
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=True

# Celery + Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
